{
  "name": "danestves-dev",
  "private": true,
  "description": "",
  "license": "GPL-3.0-only",
  "author": {
    "name": "Daniel Esteves",
    "email": "me@danestves.com",
    "url": "https://danestves.com"
  },
  "sideEffects": false,
  "scripts": {
    "start": "cross-env NODE_ENV=production node --require ./node_modules/dotenv/config ./index.js",
    "start:mocks": "cross-env NODE_ENV=production node --require ./mocks --require ./node_modules/dotenv/config ./index.js",
    "dev": "run-p dev:*",
    "dev:css": "npm run generate:css -- --watch",
    "dev:remix": "remix watch",
    "dev:server": "cross-env NODE_ENV=development node --inspect --require ./mocks ./index.js",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "pretest:e2e:run": "npm run build",
    "test:e2e:run": "cross-env PORT=8811 start-server-and-test start:mocks http://localhost:8811 \"cypress run\"",
    "test": "vitest",
    "test:e2e:dev": "start-server-and-test dev http://localhost:3000 \"cypress open\"",
    "postinstall": "metronome setup",
    "build": "run-s build:*",
    "postbuild": "metronome postbuild",
    "build:css": "npm run generate:css -- --production",
    "build:remix": "cross-env NODE_ENV=production dotenv -e .env remix build --sourcemap",
    "build:server": "node ./other/build-server.js",
    "format": "prettier --write .",
    "generate:css": "postcss styles/**/*.css --base styles --dir app/styles",
    "setup": "prisma migrate dev && prisma db seed",
    "typecheck": "tsc -b && tsc -b cypress",
    "validate": "run-p \"test -- --run\" lint typecheck test:e2e:run"
  },
  "eslintIgnore": [
    "/node_modules",
    "/build",
    "/public/build",
    "/server-build"
  ],
  "dependencies": {
    "@balavishnuvj/remix-seo": "^1.0.2",
    "@headlessui/react": "^0.0.0-insiders.b4a4e0b",
    "@heroicons/react": "^1.0.6",
    "@next-boost/hybrid-disk-cache": "^0.3.0",
    "@prisma/client": "^3.12.0",
    "@remix-run/node": "^1.4.0",
    "@remix-run/react": "^1.4.0",
    "@remix-run/serve": "^1.4.0",
    "@remix-run/server-runtime": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^1.1.1",
    "compression": "^1.7.4",
    "cross-env": "^7.0.3",
    "dotenv": "^16.0.0",
    "express": "^4.17.3",
    "fathom-client": "^3.4.1",
    "fs-extra": "^10.0.1",
    "i18next": "^21.6.16",
    "i18next-browser-languagedetector": "^6.1.4",
    "i18next-fs-backend": "^1.1.4",
    "i18next-http-backend": "^1.4.0",
    "isbot": "^3.4.5",
    "metronome-sh": "^1.3.2",
    "morgan": "^1.10.0",
    "nanoid": "^3.3.2",
    "on-finished": "^2.4.1",
    "path-to-regexp": "^6.2.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-i18next": "^11.16.6",
    "remix-etag": "^0.2.1",
    "remix-fathom": "^0.0.9",
    "remix-i18next": "^4.0.0",
    "remix-image": "^0.3.16",
    "remix-themes": "^1.1.4",
    "remix-utils": "^3.0.0",
    "sharp": "^0.30.3",
    "tiny-invariant": "^1.2.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^6.1.2",
    "@remix-run/dev": "^1.4.0",
    "@remix-run/eslint-config": "^1.4.0",
    "@testing-library/cypress": "^8.0.2",
    "@testing-library/dom": "^8.13.0",
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.1.1",
    "@testing-library/user-event": "^14.1.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/compression": "^1.7.2",
    "@types/eslint": "^8.4.1",
    "@types/express": "^4.17.13",
    "@types/i18next-fs-backend": "^1.1.2",
    "@types/morgan": "^1.9.3",
    "@types/node": "^17.0.24",
    "@types/on-finished": "^2.3.1",
    "@types/react": "^18.0.5",
    "@types/react-dom": "^18.0.1",
    "@types/sharp": "^0.30.2",
    "@types/tailwindcss": "^3.0.10",
    "@vitejs/plugin-react": "^1.3.1",
    "autoprefixer": "^10.4.4",
    "c8": "^7.11.0",
    "cssnano": "^5.1.7",
    "cypress": "^9.5.4",
    "dotenv-cli": "^5.1.0",
    "esbuild": "^0.14.36",
    "esbuild-register": "^3.3.2",
    "eslint": "^8.13.0",
    "eslint-config-prettier": "^8.5.0",
    "happy-dom": "^2.55.0",
    "msw": "^0.39.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.12",
    "postcss-cli": "^9.1.0",
    "postcss-import": "^14.1.0",
    "prettier": "2.6.2",
    "prettier-plugin-tailwindcss": "^0.1.8",
    "prisma": "^3.12.0",
    "start-server-and-test": "^1.14.0",
    "tailwindcss": "^3.0.24",
    "ts-node": "^10.7.0",
    "tsconfig-paths": "^3.14.1",
    "typescript": "^4.6.3",
    "vite": "^2.9.5",
    "vite-tsconfig-paths": "^3.4.1",
    "vitest": "^0.9.3"
  },
  "engines": {
    "node": "16",
    "npm": "8"
  },
  "prisma": {
    "seed": "ts-node --require tsconfig-paths/register prisma/seed.ts"
  }
}
